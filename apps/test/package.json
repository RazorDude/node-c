{
  "name": "@node-c/app-test",
  "version": "1.0.0-beta0",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:clean": "rm -rf dist/* && rm -f *.tsbuildinfo && npm run build",
    "check-types": "tsc -p tsconfig.build.json --noEmit",
    "generate:datasource-files": "DATASOURCE_ENV=${DATASOURCE_ENV} MODULE_NAMES=${MODULE_NAMES} npx @node-c/core generateDatasourceFiles",
    "generate:datasource-files:local": "DATASOURCE_ENV=${DATASOURCE_ENV} MODULE_NAMES=${MODULE_NAMES} node ../../packages/core/dist/scripts/generateDatasourceFiles.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "start:dev": "nest start src/main.ts --watch",
    "start:test": "NODE_ENV=endToEndTests nest start src/main.ts --watch",
    "test": "NODE_ENV=endToEndTests vitest --config test/vitest.config.ts",
    "test:coverage": "NODE_ENV=endToEndTests vitest --config test/vitest.config.ts --coverage",
    "typeorm": "typeorm-ts-node-commonjs",
    "typeorm:migration:generate:db": "npm run typeorm -- migration:generate -d datasource-db-${DATASOURCE_ENV}.ts ${MIGRATION_NAME}",
    "typeorm:migration:generate:dbConfigs": "npm run typeorm -- migration:generate -d datasource-dbConfigs-${DATASOURCE_ENV}.ts ${MIGRATION_NAME}",
    "typeorm:migration:run:db": "npm run typeorm -- migration:run -d datasource-db-${DATASOURCE_ENV}.ts",
    "typeorm:migration:run:dbConfigs": "npm run typeorm -- migration:run -d datasource-dbConfigs-${DATASOURCE_ENV}.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "mysql2": "^3.14.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "madge": "^8.0.0",
    "nestjs-spelunker": "^1.3.2",
    "ts-node": "^10.9.2"
  },
  "peerDependencies": {
    "@node-c/api-http": "^1.0.0-beta0",
    "@node-c/api-rest": "^1.0.0-beta0",
    "@node-c/core": "^1.0.0-beta0",
    "@node-c/data-clickhouse": "^1.0.0-beta0",
    "@node-c/data-redis": "^1.0.0-beta0",
    "@node-c/data-typeorm": "^1.0.0-beta0",
    "@node-c/domain-iam": "^1.0.0-beta0",
    "@node-c/domain-iam-okta": "^1.0.0-beta0"
  }
}
